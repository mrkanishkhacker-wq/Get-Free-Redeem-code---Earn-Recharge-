                                      fontWeight: FontWeight.bold,
                                      color: Colors.white),
                                ),
                              ],
                            ),
                          ),
                          const SizedBox(height: 16),
                          ElevatedButton(
                            onPressed: adShown
                                ? null
                                : () async {
                                    try {
                                      final doc = await _firestore
                                          .collection('users')
