  // FIX #4 + FIX #3: Coins sub-collection mein, rounding fix
  Future<void> _addCoinsViaFirestore(double amount, String source) async {
    try {
      final userRef = _firestore.collection('users').doc(userUID);
      final userDoc = await userRef.get();

      if (!mounted) return; // FIX #1

      final rawCoins = (userDoc['coins'] ?? 0.0).toDouble();
      final newBalance =
          double.parse((rawCoins + amount).toStringAsFixed(2));

      await userRef.update({
        'coins': newBalance,
        'totalEarned': FieldValue.increment(amount),
      });

      await userRef.collection('history').add({
        'source': source,
        'amount': double.parse(amount.toStringAsFixed(2)),
        'timestamp': FieldValue.serverTimestamp(),
      });

      if (!mounted) return; // FIX #1

      setState(() => currentBalance = newBalance);
      _prefs.setDouble('coins', currentBalance);
      _showAnimatedCoinToast('+${amount.toStringAsFixed(2)} Coins Added!');
    } catch (e) {
      if (mounted) {
        Fluttertoast.showToast(msg: 'Error adding coins: $e');
      }
    }
  }

  void _showAnimatedCoinToast(String message) {
    if (!mounted) return; // FIX #1

    final overlay = Overlay.of(context);
    late AnimationController animationController;
    animationController = AnimationController(
      duration: const Duration(milliseconds: 500),
      vsync: this,
    );
    final animation =
        Tween<double>(begin: -100, end: 0).animate(animationController);

    final overlayEntry = OverlayEntry(
      builder: (ctx) => Positioned(
        top: MediaQuery.of(ctx).size.height * 0.4,
        left: 0,
        right: 0,
        child: AnimatedBuilder(
          animation: animation,
          builder: (ctx, child) => Transform.translate(
            offset: Offset(0, animation.value),
            child: Center(
              child: Material(
                elevation: 10,
                borderRadius: BorderRadius.circular(20),
                color: Colors.transparent,
                child: Container(
                  padding: const EdgeInsets.symmetric(
                      horizontal: 30, vertical: 16),
                  decoration: BoxDecoration(
                    gradient: const LinearGradient(
                      colors: [Color(0xFF7C3AED), Color(0xFF6D28D9)],
                    ),
                    borderRadius: BorderRadius.circular(20),
                    boxShadow: [
                      BoxShadow(
                          color: Colors.purple.withOpacity(0.5),
                          blurRadius: 15,
                          spreadRadius: 2),
                    ],
                  ),
                  child: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      const Text('🎉 ', style: TextStyle(fontSize: 24)),
                      const SizedBox(width: 10),
                      Text(
                        message,
                        style: const TextStyle(
                            fontSize: 18,
                            fontWeight: FontWeight.bold,
                            color: Colors.white),
                      ),
                    ],
                  ),
                ),
              ),
            ),
          ),
        ),
      ),
    );

    overlay.insert(overlayEntry);
    animationController.forward();

    Future.delayed(const Duration(seconds: 2), () {
      animationController.reverse();
      Future.delayed(const Duration(milliseconds: 500), () {
        try {
          if (overlayEntry.mounted) overlayEntry.remove();
          animationController.dispose();
        } catch (_) {}
      });
    });
  }

