  }) : super(key: key);

  @override
  State<ScratchWinPage> createState() => _ScratchWinPageState();
}

class _ScratchWinPageState extends State<ScratchWinPage> {
  late double winAmount;
  bool isScratched = false;
  bool adShown = false;
  bool canClaim = false;
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  double currentCoins = 0.0;

  @override
  void initState() {
    super.initState();
    _checkDailyLimitAndGetCoins();
  }

  Future<void> _checkDailyLimitAndGetCoins() async {
    try {
      final doc = await _firestore
          .collection('users')
          .doc(widget.userUID)
          .get();

      if (!mounted) return; // FIX #1

      if (doc.exists) {
        // FIX #3: Rounding fix
        currentCoins = double.parse(
            ((doc['coins'] ?? 0.0).toDouble()).toStringAsFixed(2));

        final lastScratchDate =
            doc['lastScratchDate'] as Timestamp?;
        final now = DateTime.now();

        if (lastScratchDate != null) {
          final lastDate = lastScratchDate.toDate();
          final lastDateOnly =
              DateTime(lastDate.year, lastDate.month, lastDate.day);
          final todayOnly =
              DateTime(now.year, now.month, now.day);

          if (!lastDateOnly.isAtSameMomentAs(todayOnly)) {
            await _firestore
                .collection('users')
                .doc(widget.userUID)
                .update({
              'scratchCountToday': 0,
              'lastScratchDate': FieldValue.serverTimestamp(),
            });
          }
        } else {
          await _firestore
              .collection('users')
              .doc(widget.userUID)
              .update({
            'lastScratchDate': FieldValue.serverTimestamp(),
            'scratchCountToday': 0,
          });
        }
      }

      winAmount = _calculateScratchWin(currentCoins);

      if (!mounted) return; // FIX #1

      setState(() => canClaim = true);
    } catch (e) {
      winAmount = 1.0;
      if (mounted) setState(() => canClaim = true);
    }
  }

  // FIX #3: Balanced reward logic — no rounding errors, no 0.0000001 amounts
  double _calculateScratchWin(double currentCoins) {
    final random = Random();
    if (currentCoins < 800) {
      final result = (random.nextInt(5) + 1).toDouble();
      return double.parse(result.toStringAsFixed(2));
    } else {
      const outcomes = [0.50, 0.75, 1.00, 1.25, 1.50];
      final idx = random.nextInt(outcomes.length);
      return outcomes[idx];
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Scratch & Win'),
        backgroundColor: const Color(0xFF7C3AED),
      ),
      body: !canClaim
          ? const Center(child: CircularProgressIndicator())
          : Center(
              child: SingleChildScrollView(
                child: Column(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    const Padding(
                      padding: EdgeInsets.all(16),
                      child: Text(
                        'Scratch the card to reveal your prize!\n(Need 90% scratch to unlock)',
                        style: TextStyle(
                            fontSize: 18, fontWeight: FontWeight.bold),
                        textAlign: TextAlign.center,
                      ),
                    ),
                    const SizedBox(height: 32),
                    SizedBox(
                      width: 260,
                      height: 260,
                      child: Scratcher(
                        brushSize: 100,
                        threshold: 90,
                        color: const Color(0xFF7C3AED),
                        onChange: (value) {
                          if (value > 90 && !isScratched) {
                            if (mounted) {
                              setState(() => isScratched = true);
                            }
                          }
                        },
                        child: Container(
                          decoration: BoxDecoration(
                            gradient: LinearGradient(
                              colors: [
                                Colors.purple.shade400,
                                Colors.purple.shade700
                              ],
                            ),
                            borderRadius: BorderRadius.circular(20),
                          ),
                          child: const Center(
                            child: Column(
                              mainAxisAlignment:
                                  MainAxisAlignment.center,
                              children: [
                                Text('🎁',
                                    style: TextStyle(fontSize: 80)),
                                SizedBox(height: 16),
                                Text(
                                  'Scratch to Reveal',
                                  style: TextStyle(
                                      fontSize: 18,
                                      fontWeight: FontWeight.bold,
