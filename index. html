// FIX #4: CoinHistory ab sub-collection se aayega
// FIX #3: Rounding error fix
class CoinHistory {
  final String source;
  final double amount;
  final DateTime timestamp;

  CoinHistory({
    required this.source,
    required this.amount,
    required this.timestamp,
  });

  factory CoinHistory.fromMap(Map<String, dynamic> map) {
    return CoinHistory(
      source: map['source'] ?? '',
      amount: double.parse(
          ((map['amount'] ?? 0.0).toDouble()).toStringAsFixed(2)),
      timestamp: map['timestamp'] != null
          ? (map['timestamp'] as Timestamp).toDate()
          : DateTime.now(),
    );
  }
}

class WithdrawalRequest {
  final String id;
  final String userUID;
  final double amount;
  final String method;
  final String accountDetails;
  final String status;
  final DateTime createdAt;

  WithdrawalRequest({
    required this.id,
    required this.userUID,
    required this.amount,
    required this.method,
    required this.accountDetails,
    required this.status,
    required this.createdAt,
  });

  factory WithdrawalRequest.fromMap(Map<String, dynamic> map, String docId) {
    return WithdrawalRequest(
      id: docId,
      userUID: map['userUID'] ?? '',
      amount: double.parse(
          ((map['amount'] ?? 0.0).toDouble()).toStringAsFixed(2)),
      method: map['method'] ?? '',
      accountDetails: map['accountDetails'] ?? '',
      status: map['status'] ?? 'pending',
      createdAt: map['createdAt'] != null
          ? (map['createdAt'] as Timestamp).toDate()
          : DateTime.now(),
    );
  }
}

