// QUIZ DETAIL PAGE
// ===========================================================================
class QuizDetailPage extends StatefulWidget {
  final Quiz quiz;
  final Function(int) onCoinsEarned;

  const QuizDetailPage({
    Key? key,
    required this.quiz,
    required this.onCoinsEarned,
  }) : super(key: key);

  @override
  State<QuizDetailPage> createState() => _QuizDetailPageState();
}

class _QuizDetailPageState extends State<QuizDetailPage> {
  int currentQuestionIndex = 0;
  int score = 0;
  bool quizFinished = false;
  int? selectedAnswer;
  bool answered = false;

  void _answerQuestion(int idx) {
    if (answered) return;
    setState(() {
      selectedAnswer = idx;
      answered = true;
      if (idx ==
          widget.quiz.questions[currentQuestionIndex]
              .correctAnswerIndex) {
        score++;
      }
    });

    Future.delayed(const Duration(milliseconds: 900), () {
      if (!mounted) return; // FIX #1

      if (currentQuestionIndex <
          widget.quiz.questions.length - 1) {
        setState(() {
          currentQuestionIndex++;
          selectedAnswer = null;
          answered = false;
        });
      } else {
        setState(() => quizFinished = true);
        final int earned =
            score == widget.quiz.questions.length
                ? widget.quiz.rewardCoins
                : 5;
        widget.onCoinsEarned(earned);
      }
    });
  }

  @override
  Widget build(BuildContext context) {
    // ---- Result Screen ----
    if (quizFinished) {
      final bool perfect =
          score == widget.quiz.questions.length;
      return Scaffold(
        appBar: AppBar(
          title: Text(widget.quiz.title),
          backgroundColor: const Color(0xFF7C3AED),
        ),
        body: Center(
          child: Padding(
            padding: const EdgeInsets.all(24),
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Text(
                  perfect ? '🏆' : '📝',
                  style: const TextStyle(fontSize: 80),
                ),
                const SizedBox(height: 16),
                Text(
                  'Score: $score / ${widget.quiz.questions.length}',
                  style: const TextStyle(
                      fontSize: 28, fontWeight: FontWeight.bold),
                ),
                const SizedBox(height: 12),
                Text(
                  perfect
                      ? '🎉 Perfect! You earned ${widget.quiz.rewardCoins} coins!'
                      : 'You earned 5 coins.\nTry again for full reward!',
                  style: const TextStyle(fontSize: 16),
                  textAlign: TextAlign.center,
                ),
                const SizedBox(height: 32),
                ElevatedButton(
                  onPressed: () => Navigator.pop(context),
                  style: ElevatedButton.styleFrom(
                    backgroundColor: const Color(0xFF7C3AED),
                    padding: const EdgeInsets.symmetric(
                        horizontal: 40, vertical: 14),
                    shape: RoundedRectangleBorder(
                        borderRadius: BorderRadius.circular(50)),
                  ),
                  child: const Text(
                    'Back to Quizzes',
                    style: TextStyle(
                        color: Colors.white, fontSize: 16),
                  ),
                ),
              ],
            ),
          ),
        ),
      );
    }

    // ---- Question Screen ----
    final question =
        widget.quiz.questions[currentQuestionIndex];

    return Scaffold(
      appBar: AppBar(
        title: Text(widget.quiz.title),
        backgroundColor: const Color(0xFF7C3AED),
      ),
      body: Padding(
        padding: const EdgeInsets.all(20),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            ClipRRect(
              borderRadius: BorderRadius.circular(8),
              child: LinearProgressIndicator(
                value: (currentQuestionIndex + 1) /
                    widget.quiz.questions.length,
                backgroundColor: Colors.grey[200],
                color: const Color(0xFF7C3AED),
                minHeight: 8,
              ),
            ),
            const SizedBox(height: 8),
            Text(
              'Question ${currentQuestionIndex + 1} of ${widget.quiz.questions.length}',
              style: TextStyle(
                  color: Colors.grey[600], fontSize: 13),
            ),
            const SizedBox(height: 24),
            Text(
              question.text,
              style: const TextStyle(
                  fontSize: 20, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 32),
            ...List.generate(question.options.length, (idx) {
              Color btnColor = const Color(0xFF7C3AED);
              if (answered) {
                if (idx == question.correctAnswerIndex) {
                  btnColor = Colors.green;
                } else if (idx == selectedAnswer) {
                  btnColor = Colors.red;
                }
              }
              return Padding(
                padding:
                    const EdgeInsets.symmetric(vertical: 6),
                child: SizedBox(
                  width: double.infinity,
                  child: ElevatedButton(
                    onPressed: answered
                        ? null
                        : () => _answerQuestion(idx),
                    style: ElevatedButton.styleFrom(
                      backgroundColor: btnColor,
                      padding: const EdgeInsets.symmetric(
                          vertical: 14),
                      shape: RoundedRectangleBorder(
                          borderRadius:
                              BorderRadius.circular(12)),
                    ),
                    child: Text(
                      question.options[idx],
                      style: const TextStyle(
                          color: Colors.white, fontSize: 16),
                    ),
                  ),
                ),
              );
            }),
          ],
        ),
      ),
    );
  }
}

// ===========================================================================
// COIN HISTORY PAGE
// FIX #4: Sub-collection se fetch
// FIX #7: Pagination — 20 at a time
// FIX #13: Better empty state
// ===========================================================================
class CoinHistoryPage extends StatefulWidget {
  final String userUID;

  const CoinHistoryPage({Key? key, required this.userUID})
      : super(key: key);

  @override
  State<CoinHistoryPage> createState() => _CoinHistoryPageState();
}

class _CoinHistoryPageState extends State<CoinHistoryPage> {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  final List<CoinHistory> _history = [];
  DocumentSnapshot? _lastDoc;
  bool _isLoading = false;
  bool _hasMore = true;
  static const int _pageSize = 20;

  @override
  void initState() {
    super.initState();
    _loadHistory();
  }

  Future<void> _loadHistory() async {
    if (_isLoading || !_hasMore) return;
    if (mounted) setState(() => _isLoading = true);

    try {
      Query query = _firestore
          .collection('users')
          .doc(widget.userUID)
          .collection('history')
          .orderBy('timestamp', descending: true)
          .limit(_pageSize);

      if (_lastDoc != null) {
        query = query.startAfterDocument(_lastDoc!);
      }

      final snapshot = await query.get();

      if (!mounted) return; // FIX #1

      if (snapshot.docs.isNotEmpty) {
        _lastDoc = snapshot.docs.last;
        final newItems = snapshot.docs
            .map((d) => CoinHistory.fromMap(
                d.data() as Map<String, dynamic>))
            .toList();
        setState(() {
          _history.addAll(newItems);
          _hasMore = snapshot.docs.length == _pageSize;
        });
      } else {
        setState(() => _hasMore = false);
      }
    } catch (e) {
      if (mounted) {
        Fluttertoast.showToast(msg: 'History load error: $e');
      }
    } finally {
      if (mounted) setState(() => _isLoading = false);
    }
  }

  String _formatDate(DateTime dt) {
    return '${dt.day.toString().padLeft(2, '0')}/'
        '${dt.month.toString().padLeft(2, '0')}/'
        '${dt.year}  '
        '${dt.hour.toString().padLeft(2, '0')}:'
        '${dt.minute.toString().padLeft(2, '0')}';
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Coin History'),
        backgroundColor: const Color(0xFF7C3AED),
      ),
      body: _history.isEmpty && _isLoading
          ? const Center(child: CircularProgressIndicator())
          : _history.isEmpty && !_isLoading
              ? const Center(
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      Text('🪙', style: TextStyle(fontSize: 60)),
                      SizedBox(height: 16),
                      Text(
                        'Abhi tak koi transaction nahi!',
                        style: TextStyle(
                            fontSize: 16, color: Colors.grey),
                      ),
                    ],
                  ),
                )
              : ListView.builder(
                  itemCount:
                      _history.length + (_hasMore ? 1 : 0),
                  itemBuilder: (context, index) {
                    if (index == _history.length) {
                      return Padding(
                        padding: const EdgeInsets.all(16),
                        child: _isLoading
                            ? const Center(
                                child:
                                    CircularProgressIndicator())
                            : ElevatedButton.icon(
                                onPressed: _loadHistory,
                                style: ElevatedButton.styleFrom(
                                  backgroundColor:
                                      const Color(0xFF7C3AED),
                                  shape: RoundedRectangleBorder(
                                      borderRadius:
                                          BorderRadius.circular(
                                              12)),
                                ),
                                icon: const Icon(Icons.refresh,
                                    color: Colors.white),
                                label: const Text('Load More',
                                    style: TextStyle(
                                        color: Colors.white)),
                              ),
                      );
                    }

                    final item = _history[index];
                    return Card(
                      margin: const EdgeInsets.symmetric(
                          horizontal: 12, vertical: 4),
                      shape: RoundedRectangleBorder(
                          borderRadius:
                              BorderRadius.circular(12)),
                      child: ListTile(
                        leading: const CircleAvatar(
                          backgroundColor: Color(0xFFEDE9FE),
                          child: Text('🪙',
                              style: TextStyle(fontSize: 22)),
                        ),
                        title: Text(
                          item.source,
                          style: const TextStyle(
                              fontWeight: FontWeight.bold),
                        ),
                        subtitle: Text(
                            _formatDate(item.timestamp)),
                        trailing: Text(
                          '+${item.amount.toStringAsFixed(2)}',
                          style: const TextStyle(
                              color: Colors.green,
                              fontWeight: FontWeight.bold,
                              fontSize: 16),
                        ),
                      ),
                    );
                  },
                ),
    );
  }
}

