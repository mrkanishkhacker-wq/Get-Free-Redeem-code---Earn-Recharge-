  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> with TickerProviderStateMixin {
  late SharedPreferences _prefs;
  final FirebaseAuth _auth = FirebaseAuth.instance;
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;

  double currentBalance = 0.0;
  String userUID = '';
  String profileName = 'User';
  bool isLoadingBalance = true;
  bool newUserBonusClaimed = false;
  String profilePicture = '';
  bool _isClaimingBonus = false;
  String _referralCode = '';

  // FIX #2: Double-tap-to-exit
  DateTime? _lastBackPressTime;

  BannerAd? _bannerAd;
  bool _isBannerAdLoaded = false;
  RewardedAd? _rewardedAd;
  InterstitialAd? _interstitialAd;
  AppOpenAd? _appOpenAd;

  @override
  void initState() {
    super.initState();
    _initializeApp();
    _setupFCMListeners();
  }

  // FCM: Foreground notification listener
  void _setupFCMListeners() {
    FirebaseMessaging.onMessage.listen((RemoteMessage message) {
      if (!mounted) return;
      final notification = message.notification;
      if (notification != null) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(
                '🔔 ${notification.title ?? 'Notification'}: ${notification.body ?? ''}'),
            backgroundColor: const Color(0xFF7C3AED),
            behavior: SnackBarBehavior.floating,
            duration: const Duration(seconds: 4),
          ),
        );
      }
    });
  }

  Future<void> _initializeApp() async {
    try {
      _prefs = await SharedPreferences.getInstance();
      _loadLocalBalance();
      userUID = _auth.currentUser?.uid ?? 'unknown';
      profilePicture = _auth.currentUser?.photoURL ?? '';

      await _syncBalance();

      if (!mounted) return; // FIX #1

      _loadBannerAd();
      _loadRewardedAd();
      _loadInterstitialAd();
      _loadAppOpenAd();

      setState(() => isLoadingBalance = false);
    } catch (e) {
      if (mounted) setState(() => isLoadingBalance = false);
    }
  }

  void _loadLocalBalance() {
    currentBalance = _prefs.getDouble('coins') ?? 0.0;
    newUserBonusClaimed = _prefs.getBool('newUserBonusClaimed') ?? false;
