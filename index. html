class _DailySpinPageState extends State<DailySpinPage>
    with SingleTickerProviderStateMixin {
  late AnimationController _animationController;
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  bool canSpin = true;
  bool _isSpinning = false;
  int selectedSegment = 0;

  final List<int> segments = [10, 50, 100, 25, 75, 20, 150, 30];
  final List<Color> colors = [
    Colors.red,
    Colors.blue,
    Colors.green,
    Colors.orange,
    Colors.purple,
    Colors.pink,
    Colors.teal,
    Colors.amber,
  ];

  @override
  void initState() {
    super.initState();
    _animationController = AnimationController(
      duration: const Duration(seconds: 5),
      vsync: this,
    );
    _checkDailySpinLimit();
  }

  Future<void> _checkDailySpinLimit() async {
    try {
      final doc = await _firestore
          .collection('users')
          .doc(widget.userUID)
          .get();

      if (!mounted) return; // FIX #1

      if (doc.exists) {
        final lastSpinDate = doc['lastSpinDate'] as Timestamp?;
        final now = DateTime.now();

        if (lastSpinDate != null) {
          final lastDate = lastSpinDate.toDate();
          final lastDateOnly =
              DateTime(lastDate.year, lastDate.month, lastDate.day);
          final todayOnly =
              DateTime(now.year, now.month, now.day);

          if (lastDateOnly.isAtSameMomentAs(todayOnly) ||
              lastDateOnly.isAfter(todayOnly)) {
            setState(() => canSpin = false);
            Fluttertoast.showToast(
                msg: 'Kal wapis aao spin karne ke liye! 🔄');
          }
        }
      }
    } catch (e) {
      // Silently ignore
    }
  }

  void _spin() async {
    if (!canSpin || _isSpinning) {
      Fluttertoast.showToast(
          msg: 'Aaj ka spin ho chuka! Kal wapis aao.');
      return;
    }

    if (!mounted) return; // FIX #1

    setState(() {
      _isSpinning = true;
      canSpin = false;
      selectedSegment = Random().nextInt(segments.length);
    });

    _animationController.forward(from: 0.0).then((_) async {
      final int coins = segments[selectedSegment];

      try {
        await _firestore
            .collection('users')
            .doc(widget.userUID)
            .update({
          'lastSpinDate': FieldValue.serverTimestamp(),
        });

        widget.onCoinsEarned(coins);

        if (!mounted) return; // FIX #1

        setState(() => _isSpinning = false);

        // FIX #14: Better win dialog
        showDialog(
          context: context,
          builder: (ctx) => AlertDialog(
            title: const Text('🎉 Congratulations!'),
            content: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                const Text('Aapne jeeta:',
                    style: TextStyle(fontSize: 16)),
                const SizedBox(height: 8),
                Text(
                  '$coins Coins!',
                  style: const TextStyle(
                      fontSize: 32,
                      fontWeight: FontWeight.bold,
                      color: Color(0xFF7C3AED)),
                ),
              ],
            ),
            actions: [
              TextButton(
                onPressed: () => Navigator.pop(ctx),
                child: const Text('OK 🎯'),
              ),
            ],
          ),
        );
      } catch (e) {
        if (mounted) {
          Fluttertoast.showToast(msg: 'Spin error: $e');
          setState(() => _isSpinning = false);
        }
      }
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Daily Spin'),
        backgroundColor: const Color(0xFF7C3AED),
      ),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            const SizedBox(height: 20),
            const Text(
              'Spin & Win Coins!',
              style: TextStyle(
                  fontSize: 22, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 8),
            // FIX #14: Spin status text
            Text(
